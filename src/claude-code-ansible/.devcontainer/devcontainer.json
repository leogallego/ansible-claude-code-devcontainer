{
  "name": "Ansible Development (Claude Code)",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${templateOption:timezone}",
      "CLAUDE_CODE_VERSION": "${templateOption:claudeCodeVersion}"
    }
  },
  "runArgs": [
    "--cap-add=CAP_MKNOD",
    "--cap-add=NET_ADMIN",
    "--cap-add=SYS_ADMIN",
    "--cap-add=SYS_RESOURCE",
    "--device=/dev/fuse",
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined",
    "--security-opt=label=disable",
    "--security-opt=unmask=/sys/fs/cgroup",
    "--userns=host",
    "--hostname=ansible-dev-container"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "redhat.ansible",
        "redhat.vscode-yaml",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.black-formatter",
        "eamodio.gitlens",
        "asciidoctor.asciidoctor-vscode",
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.formatting.provider": "black",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "black-formatter.path": ["/usr/local/bin/black"],
        "ansible.python.interpreterPath": "/usr/bin/python3",
        "ansible.ansible.path": "/usr/local/bin/ansible",
        "ansible.validation.lint.path": "/usr/local/bin/ansible-lint",
        "ansible.validation.lint.enabled": true,
        "ansible.ansibleNavigator.path": "/usr/local/bin/ansible-navigator",
        "ansible.executionEnvironment.enabled": false,
        "ansible.executionEnvironment.image": "ghcr.io/ansible/community-ee-base:latest",
        "yaml.schemas": {
          "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json": ["playbooks/*.yml", "playbooks/*.yaml", "**/tasks/*.yml", "**/tasks/*.yaml"]
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          }
        }
      }
    }
  },
  "remoteUser": "root",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/root/.claude,type=volume",
    "source=claude-code-vscode-extensions-${devcontainerId},target=/root/.vscode-server/extensions,type=volume",
    "source=${localEnv:HOME}/.config/gcloud,target=/root/.config/gcloud,type=bind,readonly"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/root/.claude",
    "CLAUDE_CODE_USE_VERTEX": "${localEnv:CLAUDE_CODE_USE_VERTEX}",
    "ANTHROPIC_VERTEX_PROJECT_ID": "${localEnv:ANTHROPIC_VERTEX_PROJECT_ID}",
    "CLOUD_ML_REGION": "${localEnv:CLOUD_ML_REGION}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "AH_TOKEN": "${localEnv:AH_TOKEN}",
    "REGISTRY_REDHAT_IO_TOKEN": "${localEnv:REGISTRY_REDHAT_IO_TOKEN}",
    "QUAY_TOKEN": "${localEnv:QUAY_TOKEN}",
    "DOCKER_TOKEN": "${localEnv:DOCKER_TOKEN}",
    "DOCKER_USER": "${localEnv:DOCKER_USER}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "claude mcp add --scope user ansible-know -- uvx ansible-know-mcp && claude mcp add --scope user ansible -- npx -y @ansible/ansible-mcp-server --stdio && claude plugin marketplace add leogallego/claude-ansible-skills && claude plugin install ansible-docs@claude-ansible-skills --scope user && claude plugin install ansible-good-practices@claude-ansible-skills --scope user && claude plugin install ansible-scaffold-collection@claude-ansible-skills --scope user && claude plugin install ansible-scaffold-ee@claude-ansible-skills --scope user && claude plugin install ansible-scaffold-role@claude-ansible-skills --scope user && claude plugin install ansible-zen@claude-ansible-skills --scope user",
  "postStartCommand": "/usr/local/bin/init-registry-auth.sh",
  "waitFor": "postStartCommand"
}
