{
  "name": "Ansible Development Tools (AI & Claude Code)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--cap-add=CAP_MKNOD",
    "--cap-add=NET_ADMIN",
    "--cap-add=SYS_ADMIN",
    "--cap-add=SYS_RESOURCE",
    "--device=/dev/fuse",
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined",
    "--security-opt=label=disable",
    "--security-opt=unmask=/sys/fs/cgroup",
    "--userns=host",
    "--hostname=ansible-dev-container"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "redhat.ansible",
        "redhat.vscode-yaml",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "eamodio.gitlens",
        "asciidoctor.asciidoctor-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "black-formatter.path": ["/usr/local/bin/black"],
        "ansible.python.interpreterPath": "/usr/bin/python3",
        "ansible.ansible.path": "/usr/local/bin/ansible",
        "ansible.validation.lint.path": "/usr/local/bin/ansible-lint",
        "ansible.validation.lint.enabled": true,
        "ansible.ansibleNavigator.path": "/usr/local/bin/ansible-navigator",
        "ansible.executionEnvironment.enabled": false,
        "ansible.executionEnvironment.image": "ghcr.io/ansible/community-ee-base:latest",
        "yaml.schemas": {
          "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json": ["playbooks/*.yml", "playbooks/*.yaml", "**/tasks/*.yml", "**/tasks/*.yaml"]
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          }
        }
      }
    }
  },
  "remoteUser": "root",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/root/.claude,type=volume",
    "source=claude-code-vscode-extensions-${devcontainerId},target=/root/.vscode-server/extensions,type=volume",
    "source=${localEnv:HOME}/.config/gcloud,target=/root/.config/gcloud,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly",
    "source=claude-code-gh-config-${devcontainerId},target=/root/.config/gh,type=volume"
  ],
  "initializeCommand": "mkdir -p ${HOME}/.config/gcloud; touch ${HOME}/.gitconfig 2>/dev/null || true",
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "HISTFILE": "/commandhistory/.bash_history",
    "CLAUDE_CONFIG_DIR": "/root/.claude",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "CLAUDE_CODE_USE_VERTEX": "${localEnv:CLAUDE_CODE_USE_VERTEX}",
    "ANTHROPIC_VERTEX_PROJECT_ID": "${localEnv:ANTHROPIC_VERTEX_PROJECT_ID}",
    "CLOUD_ML_REGION": "${localEnv:CLOUD_ML_REGION}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "AH_TOKEN": "${localEnv:AH_TOKEN}",
    "REGISTRY_REDHAT_IO_TOKEN": "${localEnv:REGISTRY_REDHAT_IO_TOKEN}",
    "QUAY_TOKEN": "${localEnv:QUAY_TOKEN}",
    "DOCKER_TOKEN": "${localEnv:DOCKER_TOKEN}",
    "DOCKER_USER": "${localEnv:DOCKER_USER}",
    "ANSIBLE_GALAXY_SERVER_AH_TOKEN": "${localEnv:ANSIBLE_GALAXY_SERVER_AH_TOKEN}",
    "ANSIBLE_GALAXY_SERVER_AUTOMATION_HUB_TOKEN": "${localEnv:ANSIBLE_GALAXY_SERVER_AUTOMATION_HUB_TOKEN}",
    "GOOGLE_VERTEX_PROJECT": "${localEnv:GOOGLE_VERTEX_PROJECT}",
    "GOOGLE_VERTEX_LOCATION": "${localEnv:GOOGLE_VERTEX_LOCATION}",
    "OPENROUTER_API_KEY": "${localEnv:OPENROUTER_API_KEY}",
    "GOOGLE_GENERATIVE_AI_API_KEY": "${localEnv:GOOGLE_GENERATIVE_AI_API_KEY}",
    "ANSIBLE_COLLECTIONS_PATH": "/workspace/collections:/root/.ansible/collections:/usr/share/ansible/collections",
    "ANSIBLE_ROLES_PATH": "/workspace/roles:/root/.ansible/roles:/usr/share/ansible/roles",
    "XDG_CACHE_HOME": "/workspace/.cache"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "mkdir -p /workspace/.ansible/{collections,roles,galaxy_cache,tmp} /workspace/.cache && (claude mcp add --scope user ansible-know -- uvx ansible-know-mcp || true) && (claude mcp add --scope user ansible -- npx -y @ansible/ansible-mcp-server --stdio || true) && (claude plugin marketplace add leogallego/claude-ansible-skills || true) && (claude plugin install ansible-docs@claude-ansible-skills --scope user || true) && (claude plugin install ansible-good-practices@claude-ansible-skills --scope user || true) && (claude plugin install ansible-scaffold-collection@claude-ansible-skills --scope user || true) && (claude plugin install ansible-scaffold-ee@claude-ansible-skills --scope user || true) && (claude plugin install ansible-scaffold-role@claude-ansible-skills --scope user || true) && (claude plugin install ansible-zen@claude-ansible-skills --scope user || true) ",
  "postStartCommand": "/usr/local/bin/init-registry-auth.sh",
  "postAttachCommand": "([ -f /opt/abbenay-provider.vsix ] && mkdir -p /root/.vscode-server/extensions && unzip -qo /opt/abbenay-provider.vsix 'extension/*' -d /tmp/abbenay-vsix && rm -rf /root/.vscode-server/extensions/redhat.abbenay-provider && mv /tmp/abbenay-vsix/extension /root/.vscode-server/extensions/redhat.abbenay-provider && rm -rf /tmp/abbenay-vsix || true)",
  "waitFor": "postStartCommand"
}
